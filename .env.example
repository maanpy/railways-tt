# ── REQUIRED ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID — get it from @userinfobot on Telegram
# Leave empty to allow anyone (not recommended)
ALLOWED_USER_IDS=123456789

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Max links per /fyp call
MAX_LINKS=200

# Scroll delay range in ms (keeps it human-like, avoids bans)
SCROLL_DELAY_MIN_MS=2500
SCROLL_DELAY_MAX_MS=4500

# Page load timeout in ms
PAGE_TIMEOUT_MS=30000

# Keep true on Railway — only set false for local dev to see the browser
HEADLESS=true
