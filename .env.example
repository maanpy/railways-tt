# ── REQUIRED ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs (leave empty = everyone allowed)
ALLOWED_USER_IDS=123456789

# ── OPTIONAL ───────────────────────────────────────────────────────────────────
# Max videos per /fyp call (hard cap, default 200)
MAX_FYP_COUNT=200

# Parallel pages when scraping metadata (2-4 recommended)
SCRAPE_CONCURRENCY=3

# Page load timeout in ms
PAGE_TIMEOUT_MS=30000

# Retries per failed link
MAX_RETRIES=2

# Set false to see the browser window (local dev only)
HEADLESS=true
